  },
  "implementation_blockers": [
    "fixed_heldout_audit_query_set_construction_size_and_sample_id_manifest",
    "uncertainty_and_utility_priority_scores_normalization_and_tie_breaking",
    "tokenizer_level_neutral_pad_exact_length_matching_algorithm",
    "paired_bundle_behavior_at_pilot_budget_ceiling_boundary",
    "sr_slope_estimator_and_task_clustered_interval_implementation",
    "shared_control_rollout_count_and_deployment_rollout_reuse_rule"
  ]
