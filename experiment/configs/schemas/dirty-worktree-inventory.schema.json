{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MERIT dirty worktree content inventory",
  "type": "object",
  "required": ["schema_version", "inventory_id", "provenance_revision", "base_commit", "head_commit", "dirty_worktree", "content_identity", "generated_envelope_exclusions", "entries", "entry_count"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "inventory_id": {"const": "dirty-worktree-20260719-v1"},
    "provenance_revision": {"const": "merit-dirty-worktree-inventory-v1"},
    "base_commit": {"const": "4280484e035191b66f77618b7729dbd465d8b828"},
    "head_commit": {"const": "4280484e035191b66f77618b7729dbd465d8b828"},
    "dirty_worktree": {"const": true},
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "path", "sha256", "size_bytes", "status"],
        "properties": {
          "kind": {"enum": ["file", "symlink"]},
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "size_bytes": {"type": "integer", "minimum": 0},
          "status": {"type": "string", "minLength": 2, "maxLength": 2}
        }
      }
    },
    "entry_count": {"type": "integer", "minimum": 1}
  },
  "additionalProperties": false
}
