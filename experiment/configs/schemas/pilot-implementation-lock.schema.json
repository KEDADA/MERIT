    "invariants": {
      "type": "object",
      "properties": {
        "pilot_confirmatory_overlap_allowed": {"const": false},
        "no_pad_main_arm_allowed": {"const": false},
        "neutral_pad_failure_downgrade": {"const": "pad-replacement contribution"},
        "redundancy_axis": {"const": "EVIDENCE GAP"},
        "formal_k_n_audit_seed_count": {"const": "POST_PILOT_COMPUTED_THEN_USER_LOCKED"},
        "governance_dead_zone": {"const": "USER_APPROVAL_REQUIRED"},
        "huber_delta": {"const": "USER_APPROVAL_REQUIRED"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
