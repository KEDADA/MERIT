    "rules": {
      "type": "object",
      "required": ["fixed_heldout_audit_query_set", "train_priority_score_contract", "neutral_pad_token_length_matching", "paired_bundle_budget_ceiling", "sr_slope_clustered_interval", "shared_control_and_deployment_reuse"],
