{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "merit/artifact-manifest.schema.json",
  "title": "MERIT artifact manifest",
  "type": "object",
  "required": ["schema_version", "run_id", "artifacts"],
  "properties": {
    "run_id": {"type": "string"},
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_id", "kind", "path_alias", "sha256", "size_bytes", "created_by"],
        "properties": {
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "size_bytes": {"type": "integer", "minimum": 0}
        }
      }
    }
  },
  "additionalProperties": true
}

